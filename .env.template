# Runtime
NODE_ENV=development
PORT=3000
WEBSITE_URL=http://localhost:3000
# Comma-separated exact origins. Never use * with credentialed requests.
# Production origins must use HTTPS and include WEBSITE_URL.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Better Auth
# Generate a unique secret of at least 32 characters for every environment.
BETTER_AUTH_SECRET=
# Browser sessions use Better Auth HttpOnly cookies. Bearer tokens remain only
# for non-browser clients that store them in platform-secure storage.

# Database (Turso / LibSQL)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Encryption at rest
# Required in production. Generate with:
#   openssl rand -base64 32
# Rotating this key requires re-encrypting stored integration credentials first.
CREDENTIAL_ENCRYPTION_KEY=

# S3-compatible property storage (Cloudflare R2, AWS S3, etc.)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Aqari ERP <onboarding@resend.dev>

# Staff invitations
# Invitations are single-use and expire after this many minutes.
INVITATION_TTL_MINUTES=1440

# WhatsApp Cloud API
# Shared Meta app secret used to verify X-Hub-Signature-256.
WHATSAPP_APP_SECRET=
# Verification token configured in the Meta webhook settings.
WA_VERIFY_TOKEN=
# Optional Graph API version override.
WHATSAPP_GRAPH_API_VERSION=v20.0
# Development only. Never enable in production.
ALLOW_UNSIGNED_WHATSAPP_WEBHOOKS=false

# Development demo data
# The /api/seed route is mounted only outside production when this is true.
ENABLE_DEMO_SEED=false
DEMO_SEED_SECRET=
# Optional fixed local-only demo password. Leave blank to generate a random one per seed.
DEMO_USER_PASSWORD=

# Optional AI gateway
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=

# Optional payments and tracking
AUTUMN_SECRET_KEY=
