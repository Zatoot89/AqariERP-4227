# ─── Runtime ──────────────────────────────────────────────────────────────────
# development | test | staging | production
NODE_ENV=development
PORT=3000
WEBSITE_URL=http://localhost:3000
# Comma-separated exact origins. Never use * with credentialed requests.
# Staging and production origins must use HTTPS and include WEBSITE_URL.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Mobile app build-time API URL (Expo). Do not include a trailing slash.
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Unique per environment; minimum 32 characters.
BETTER_AUTH_SECRET=

# ─── Database (Turso / LibSQL) ────────────────────────────────────────────────
# Local example: file:local.db
# Hosted example: libsql://database-name.turso.io
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=

# ─── Encryption at rest ───────────────────────────────────────────────────────
# Required outside local development. Generate with: openssl rand -base64 32
# Do not rotate without following docs/DEPLOYMENT.md.
CREDENTIAL_ENCRYPTION_KEY=

# ─── S3-compatible object storage ─────────────────────────────────────────────
# Cloudflare R2, AWS S3, MinIO, or another compatible provider.
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_FORCE_PATH_STYLE=false

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Aqari ERP <noreply@example.com>

# ─── Staff invitations ────────────────────────────────────────────────────────
# Single-use invitation expiry, from 15 minutes to 7 days.
INVITATION_TTL_MINUTES=1440

# ─── Task reminders ───────────────────────────────────────────────────────────
# The current single-process reminder loop can be disabled when an external
# scheduler is used. Phase 4 replaces this with durable jobs.
TASK_REMINDERS_ENABLED=true
TASK_REMINDER_INITIAL_DELAY_MS=15000
TASK_REMINDER_INTERVAL_MS=300000

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Meta app secret used to verify X-Hub-Signature-256.
WHATSAPP_APP_SECRET=
# Token configured in Meta webhook verification settings.
WA_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v20.0
# Development only. Production startup rejects true.
ALLOW_UNSIGNED_WHATSAPP_WEBHOOKS=false

# ─── Development demo data ────────────────────────────────────────────────────
# The /api/seed route is mounted only outside production when enabled.
ENABLE_DEMO_SEED=false
DEMO_SEED_SECRET=
# Optional local-only demo password. Leave blank to generate one per seed.
DEMO_USER_PASSWORD=

# ─── Optional integrations ────────────────────────────────────────────────────
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AUTUMN_SECRET_KEY=


# ─── Transaction document rendering ───────────────────────────────────────────
# Optional HTTP service that accepts { html, format, printBackground } and returns PDF bytes.
# Without it, transaction documents remain reproducible, printable HTML with status html_ready.
DOCUMENT_RENDERER_URL=
DOCUMENT_RENDERER_TOKEN=
