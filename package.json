{
  "name": "aqari-erp",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/web && bunx vite",
    "dev:desktop": "cd packages/desktop && bunx vite",
    "dev:mobile": "cd packages/mobile && bunx expo start",
    "start": "pm2 delete aqari-web 2>/dev/null || true; pm2 start ecosystem.config.cjs --update-env",
    "build": "turbo build",
    "build:web": "cd packages/web && bunx vite build",
    "lint": "oxlint . --deny-warnings --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --fix --deny-warnings --no-error-on-unmatched-pattern",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "kill:port": "lsof -t -i :${PORT:-4200} | xargs kill -9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.66.0",
    "turbo": "^2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "pm2": "^7.0.1"
  }
}
